# Entorno: development | testing | production
ENVIRONMENT=development

# Cadena de conexión a PostgreSQL (Supabase)
# Ejemplo Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/facturacion

# Seguridad JWT
JWT_SECRET_KEY=change-this-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# CORS: orígenes permitidos separados por coma
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Datos de la empresa emisora (para el PDF de facturas)
EMPRESA_RAZON_SOCIAL=Mi Empresa S.A.C.
EMPRESA_RUC=20123456789
EMPRESA_DIRECCION=Av. Ejemplo 123, Lima, Peru
IGV_PORCENTAJE=18

# Mistral AI API Key (obtener de https://admin.mistral.ai/organization/api-keys)
MISTRAL_API_KEY=
